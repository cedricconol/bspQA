OPENAI_API_KEY=sk-...
QDRANT_CLUSTER_ENDPOINT=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=bspqa

# Ingestion only — controls whether the Qdrant collection is wiped on re-ingest
# Set to "true" in local dev; always blocked in production environments
QDRANT_RECREATE_COLLECTION=false

# Environment label used by ingestion scripts and prod-safety guards
# Values: development | dev | local | production | prod
ENVIRONMENT=development
