# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Qdrant Cloud (used by ingestion/chunk_and_embed.py)
QDRANT_CLUSTER_ENDPOINT=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=bspqa

# Ingestion: collection handling (chunk_and_embed.py)
# - Railway sets RAILWAY_ENVIRONMENT=production on prod services — collection is never dropped.
# - Local dev: set ENVIRONMENT=development (or APP_ENV) to drop+recreate the collection each run.
# - Optional override: QDRANT_RECREATE_COLLECTION=true|false (ignored in production).
# ENVIRONMENT=development
# QDRANT_RECREATE_COLLECTION=true
